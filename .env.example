# Copy this file to `.env` and fill in your token.
#
# Get a free Hugging Face token at https://huggingface.co/settings/tokens
# A "Read" token is all you need.
HF_TOKEN=hf_your_token_here

# Optional: override the default model. Must be a chat model served on
# Hugging Face Inference (see https://huggingface.co/models?inference=warm).
# Good SQL-capable picks:
#   Qwen/Qwen2.5-Coder-32B-Instruct   (default — strong at SQL)
#   meta-llama/Meta-Llama-3.1-70B-Instruct
#   mistralai/Mistral-Nemo-Instruct-2407
HF_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# Optional: pin an inference provider. Leave blank for auto.
# Examples: hf-inference, together, fireworks-ai, nebius
# HF_PROVIDER=
